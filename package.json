{
  "name": "weekly-recipe-planner",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev --hostname 127.0.0.1 --port 3001",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "node scripts/start.mjs",
    "start:installed": "node --disable-warning=ExperimentalWarning scripts/start-installed.mjs",
    "start:web": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start --hostname 127.0.0.1 --port 3002",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run typecheck && npm run build && node --disable-warning=ExperimentalWarning --experimental-strip-types --test \"tests/**/*.test.mjs\"",
    "test:e2e": "playwright test",
    "test:e2e:installed": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/support/planner-installed-qa.mjs --standalone",
    "qa:serve": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/qa-portless-runtime.mjs",
    "planner:release": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/planner-release.mjs",
    "planner:service": "node --disable-warning=ExperimentalWarning scripts/planner-service.mjs",
    "planner:global": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/planner-global-client.ts",
    "probe:codex-follow-up": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/probe-codex-follow-up.mjs",
    "smoke:native-codex": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/smoke-live-chat.mjs",
    "smoke:live-chat": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/smoke-live-chat.mjs",
    "verify:codex-activation": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/verify-codex-activation.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "radix-ui": "1.6.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@cloudflare/vite-plugin": "1.44.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "ajv": "6.15.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "portless": "0.13.0",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.14"
    }
  },
  "type": "module"
}
