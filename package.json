{
  "name": "weekly-recipe-planner",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev --hostname 127.0.0.1 --port 3001",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "node scripts/start.mjs",
    "start:web": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start --hostname 127.0.0.1 --port 3002",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run typecheck && npm run build && node --experimental-strip-types --test \"tests/**/*.test.mjs\"",
    "test:e2e": "playwright test",
    "smoke:live-chat": "node --experimental-strip-types scripts/smoke-live-chat.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@playwright/test": "1.61.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.14"
    }
  },
  "type": "module"
}
